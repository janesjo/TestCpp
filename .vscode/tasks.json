{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: configure vscode-debug",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--preset",
        "vscode-debug"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "CMake: build main",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "--preset",
        "vscode-debug",
        "--target",
        "main"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "dependsOn": [
        "CMake: configure vscode-debug"
      ],
      "problemMatcher": [
        "$gcc"
      ]
    }
  ]
}
