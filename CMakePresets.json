{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "homebrew-llvm",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "/opt/homebrew/opt/llvm/bin/clang++"
      }
    },
    {
      "name": "apple-clang",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_CXX_COMPILER": "/usr/bin/c++"
      }
    },
    {
      "name": "vscode-debug",
      "displayName": "VS Code Debug",
      "description": "Debug build for VS Code CMake Tools.",
      "inherits": "homebrew-llvm",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/cmake/vscode-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "ENABLE_ASAN": "ON"
      }
    },
    {
      "name": "vscode-release",
      "displayName": "VS Code Release",
      "description": "Release build for VS Code CMake Tools.",
      "inherits": "homebrew-llvm",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/cmake/vscode-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "ENABLE_ASAN": "OFF"
      }
    },
    {
      "name": "vscode-debug-appleclang",
      "displayName": "VS Code Debug AppleClang",
      "description": "Debug build for VS Code CMake Tools using AppleClang.",
      "inherits": "apple-clang",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/cmake/vscode-debug-appleclang",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "ENABLE_ASAN": "ON"
      }
    },
    {
      "name": "vscode-release-appleclang",
      "displayName": "VS Code Release AppleClang",
      "description": "Release build for VS Code CMake Tools using AppleClang.",
      "inherits": "apple-clang",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build/cmake/vscode-release-appleclang",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "ENABLE_ASAN": "OFF"
      }
    },
    {
      "name": "xcode",
      "displayName": "Xcode",
      "description": "Generate an Xcode project.",
      "generator": "Xcode",
      "binaryDir": "${sourceDir}/build/cmake/xcode",
      "cacheVariables": {
        "ENABLE_ASAN": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "vscode-debug",
      "displayName": "Build VS Code Debug",
      "configurePreset": "vscode-debug"
    },
    {
      "name": "clean-vscode-debug",
      "displayName": "Clean VS Code Debug",
      "configurePreset": "vscode-debug",
      "targets": [
        "clean"
      ]
    },
    {
      "name": "vscode-release",
      "displayName": "Build VS Code Release",
      "configurePreset": "vscode-release"
    },
    {
      "name": "clean-vscode-release",
      "displayName": "Clean VS Code Release",
      "configurePreset": "vscode-release",
      "targets": [
        "clean"
      ]
    },
    {
      "name": "vscode-debug-appleclang",
      "displayName": "Build VS Code Debug AppleClang",
      "configurePreset": "vscode-debug-appleclang"
    },
    {
      "name": "clean-vscode-debug-appleclang",
      "displayName": "Clean VS Code Debug AppleClang",
      "configurePreset": "vscode-debug-appleclang",
      "targets": [
        "clean"
      ]
    },
    {
      "name": "vscode-release-appleclang",
      "displayName": "Build VS Code Release AppleClang",
      "configurePreset": "vscode-release-appleclang"
    },
    {
      "name": "clean-vscode-release-appleclang",
      "displayName": "Clean VS Code Release AppleClang",
      "configurePreset": "vscode-release-appleclang",
      "targets": [
        "clean"
      ]
    },
    {
      "name": "xcode-debug",
      "displayName": "Build Xcode Debug",
      "configurePreset": "xcode",
      "configuration": "Debug",
      "targets": [
        "main"
      ]
    },
    {
      "name": "clean-xcode-debug",
      "displayName": "Clean Xcode Debug",
      "configurePreset": "xcode",
      "configuration": "Debug",
      "targets": [
        "clean"
      ]
    },
    {
      "name": "xcode-release",
      "displayName": "Build Xcode Release",
      "configurePreset": "xcode",
      "configuration": "Release",
      "targets": [
        "main"
      ]
    },
    {
      "name": "clean-xcode-release",
      "displayName": "Clean Xcode Release",
      "configurePreset": "xcode",
      "configuration": "Release",
      "targets": [
        "clean"
      ]
    }
  ]
}
